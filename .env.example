# ---------------------------------------------------------------------------
# Brian's Landscaping — environment configuration
# Copy this file to `.env.local` and fill in the values for production.
# Everything is OPTIONAL for local development; forms will log to the server
# console and succeed even when no email provider is configured.
# ---------------------------------------------------------------------------

# Public site URL (used for canonical URLs, sitemap, Open Graph, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://www.brianslandscapingbethlehem.com

# --- Email notifications (Resend — https://resend.com) ----------------------
# When set, quote/booking/contact submissions email Brian + the customer.
# If unset, submissions are validated and logged but no email is sent.
RESEND_API_KEY=
# Verified "from" address on your Resend domain.
EMAIL_FROM="Brian's Landscaping <quotes@brianslandscapingbethlehem.com>"
# Where lead notifications are delivered (Brian's inbox).
LEAD_NOTIFY_EMAIL=brian@brianslandscapingbethlehem.com

# --- Optional SMS lead alerts (Twilio) --------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# --- Spam protection (Google reCAPTCHA v3, optional) ------------------------
# Honeypot + timing checks work without these. Add keys to enable reCAPTCHA.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Google Maps embed (optional) -------------------------------------------
# Used for the interactive map on the Contact page. A keyless embed is used
# as a fallback when this is not provided.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
